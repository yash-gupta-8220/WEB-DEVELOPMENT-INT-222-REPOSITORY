    <style id="BubbleLayer-0DE9E47C-871A-4F90-8440-B190C216800A-STYLE">
      @font-face {
        font-family: 'McAfeePoppins';
        src: url(chrome-extension://fheoggkfdfchfphceeifdbepaooicaho/fonts/Poppins-Regular.ttf);
      }

      #BubbleLayer-0DE9E47C-871A-4F90-8440-B190C216800A {
        background-color: #fff;
        border: 1.5px solid red;
        cursor: default;
        display: flex;
        font-family: 'McAfeePoppins', sans-serif;
        position: absolute;
        visibility: hidden;
        z-index: 2147483647;
        outline:none;
        line-height: 17px;
      }

      #balloon__content-0DE9E47C-871A-4F90-8440-B190C216800A {
        display: flex;
        flex-direction: column;
        flex: 1;
        margin: 10px;
      }
      
      #balloon__status-0DE9E47C-871A-4F90-8440-B190C216800A {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        margin: -1px;
      }

      #content__categories-0DE9E47C-871A-4F90-8440-B190C216800A > #content__cat_container {
        color: #5d7998;
        display: block;
        font-size: 12px;
        margin: 0;
        padding-left: 20px;
      }

      #content__categories-0DE9E47C-871A-4F90-8440-B190C216800A > #content__cat_container > #content__cat_item {
        display: list-item;
        list-style-type: disc;
        padding-top: 5px;
      }

      #content__header-0DE9E47C-871A-4F90-8440-B190C216800A {
        display: flex;
        padding: 5px 0; 
      }

      #content__header-0DE9E47C-871A-4F90-8440-B190C216800A > #content__title {
        color: #53565A;
        flex-grow: 1;
        font-size: 16px;
        font-weight: bold;
        margin: 0;
      }

      #content__header-0DE9E47C-871A-4F90-8440-B190C216800A > img {
        align-self: flex-start;
        display: none;
        height: 17px;
        width: 50px;
      }

      #content__link-0DE9E47C-871A-4F90-8440-B190C216800A {
        display: flex;
        flex-direction: row;
        justify-content: flex-end;
        padding-top: 5px;
        font-size: 12px;
        text-align: right;
      }

      #content__link-0DE9E47C-871A-4F90-8440-B190C216800A > a {
        color: #0084B6;
        text-decoration: underline;
        outline:none;
      }

      #content__separator-0DE9E47C-871A-4F90-8440-B190C216800A {
        background-color: #e2e4eb;
        height: 1px;
        margin: 10px 0;
      }

      #content__wa_logo-0DE9E47C-871A-4F90-8440-B190C216800A {
        display: flex;
        flex-direction: row;
        justify-content: flex-end;
      }

      #content__wa_logo-0DE9E47C-871A-4F90-8440-B190C216800A > img {
        height: 16px;
      }
    </style>
